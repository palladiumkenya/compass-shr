# JSON array of client records
# Each client has a username, password, and a key used to sign their JWTs
# key must be at least 32 characters and must match HAPI_FHIR_AUTH_JWT_SECRET in fhir.env
CLIENTS=[{"username":"your-client","password":"your-password","role":"his","key":"your-32-plus-char-hmac-secret-here"}]

# JWT expiry duration (default: 1h)
# Examples: 30m, 2h, 7d
JWT_EXPIRY=1h

# Server port (default: 7777)
PORT=7777
