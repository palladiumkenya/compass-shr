# JWT secret for validating bearer tokens issued by compass-auth
# Must be at least 32 characters and must match the key in auth_settings.env
HAPI_FHIR_AUTH_JWT_SECRET=your-32-plus-char-hmac-secret-here

# PostgreSQL — shared by both the db container and the FHIR datasource
POSTGRES_DB=hapi
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password

# Spring Boot datasource — overrides hapi.full.application.yaml values
SPRING_DATASOURCE_USERNAME=your-db-user
SPRING_DATASOURCE_PASSWORD=your-db-password
